<configuration>
  <!--
    Mono DLL mapping for System.Data.SQLite (built from source with SQLITE_STANDARD).
    P/Invoke target is "sqlite3". On Linux, Mono's global config already maps
    sqlite3 -> libsqlite3.so.0, but we include an explicit mapping as a fallback.
    On Windows, the runtime DLL map in ModEntry.cs handles the mapping to x64/sqlite3.dll.
  -->
  <dllmap dll="sqlite3" target="libsqlite3.so.0" os="linux"/>
</configuration>
